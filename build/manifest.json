{
  "manifest_version": 3,
  "name": "Entry-Fontter",
  "version": "1.0",
  "description": "엔트리에서 커스텀 웹폰트를 사용할 수 있습니다.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://playentry.org/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://playentry.org/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}